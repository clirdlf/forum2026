<!-- Requirements & Process -->
<section class="py-20 bg-secondary-fixed/30 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Checklist -->
        <div>
            <h2 class="text-3xl font-headline font-bold mb-8">Proposal Requirements</h2>
            <ul class="space-y-4">
                <li class="flex items-start gap-4 p-4 bg-white/50 rounded-lg">
                    <span class="material-symbols-outlined text-green-600 mt-0.5"
                        aria-hidden="true">check_circle</span>
                    <span>Title (up to 15 words)</span>
                </li>
                <li class="flex items-start gap-4 p-4 bg-white/50 rounded-lg">
                    <span class="material-symbols-outlined text-green-600 mt-0.5"
                        aria-hidden="true">check_circle</span>
                    <span>Abstract for program (50 words)</span>
                </li>
                <li class="flex items-start gap-4 p-4 bg-white/50 rounded-lg">
                    <span class="material-symbols-outlined text-green-600 mt-0.5"
                        aria-hidden="true">check_circle</span>
                    <span>Full proposal description (250-500 words)</span>
                </li>
                <li class="flex items-start gap-4 p-4 bg-white/50 rounded-lg">
                    <span class="material-symbols-outlined text-green-600 mt-0.5"
                        aria-hidden="true">check_circle</span>
                    <span>Description of active engagement (for sessions)</span>
                </li>
                <li class="flex items-start gap-4 p-4 bg-white/50 rounded-lg">
                    <span class="material-symbols-outlined text-green-600 mt-0.5"
                        aria-hidden="true">check_circle</span>
                    <span>Speaker bios (100 words each)</span>
                </li>
            </ul>
        </div>
        <!-- Evaluation -->
        <div class="space-y-8">
            <div>
                <h2 class="text-3xl font-headline font-bold mb-6">Evaluation &amp; Voting</h2>
                <p class="text-on-surface-variant mb-6 leading-relaxed">
                    Proposals will be evaluated through a two-stage process: a double-blind peer review by our program
                    committee followed by a community voting period. The committee considers relevance to the field,
                    clarity of goals, and contribution to diversity.
                </p>
                <div class="bg-primary/5 p-6 rounded-xl border border-primary/20">
                    <h3 class="font-bold flex items-center gap-2 mb-2">
                        <span class="material-symbols-outlined text-primary" aria-hidden="true">how_to_vote</span>
                        Community Voice
                    </h3>
                    <p class="text-sm">We believe in community-driven curation. Every DLF member has the opportunity to
                        vote on proposals they want to see in the final program.</p>
                </div>
            </div>
            <div class="p-8 bg-primary rounded-2xl text-on-primary text-center" id="submit">
                <h3 class="text-2xl font-bold mb-4">Ready to contribute?</h3>
                <p class="mb-6 opacity-90">Submissions close Monday, May 11, 2026 at 11:59 PM PT.</p>
                {% if metadata.proposal_url %}
                    <a
                        class="w-full py-4 bg-white text-primary rounded-xl font-bold hover:bg-slate-100 transition-colors shadow-lg inline-block"
                        href="{{ metadata.proposal_url }}"
                        target="_blank"
                        rel="noopener noreferrer">Submit Your Proposal Now</a>
                {% else %}
                    <p class="w-full py-4 bg-white text-primary rounded-xl font-bold shadow-lg">Proposal Portal Coming Soon</p>
                {% endif %}
            </div>
        </div>
    </div>
</section>

